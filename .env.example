# Variáveis de ambiente para configuração
# Copie este arquivo para .env e preencha com seus valores reais

# Saldo esperado para validação (ex: 15000.50)
EXPECTED_BALANCE=0.0

# Diretório de arquivo (ex: ./archive/processed)
ARCHIVE_DIR=./archive/processed

# Ano para processamento de extratos (ex: 2025)
YEAR=2025
